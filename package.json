{
  "name": "comet-bay-scoreboard",
  "version": "1.0.0",
  "description": "Comet Bay Scoreboard System",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder"
  },
  "author": "Adam",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2",
    "multer": "^1.4.5-lts.1"
  },
  "devDependencies": {
    "electron": "^28.2.0",
    "electron-builder": "^24.6.0"
  },
  "build": {
    "appId": "com.cometbay.scoreboard",
    "productName": "Comet Bay Scoreboard",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "server.js",
      "admin/**/*",
      "display/**/*",
      "package.json",
      "node_modules/**/*"
    ],
    "extraResources": [
      {
        "from": "server.js",
        "to": "server.js"
      },
      {
        "from": "node_modules",
        "to": "node_modules"
      }
    ],
    "asar": true,
    "asarUnpack": [
      "server.js",
      "node_modules/express/**/*",
      "node_modules/multer/**/*"
    ],
    "win": {
      "target": "nsis",
      "icon": "icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}
